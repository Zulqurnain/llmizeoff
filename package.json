{
  "name": "llmizeoff",
  "version": "0.4.2",
  "description": "llmizeOFF — Self-hosted LLM runtime for VPS, cPanel, Android, and local tools. OpenAI-compatible. No cloud, no subscriptions. Live demo: zulqurnainj.com/chat",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/react-native.js",
      "browser": "./dist/client.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "default": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./react-native": {
      "default": "./dist/react-native.js",
      "types": "./dist/react-native.d.ts"
    },
    "./server": {
      "default": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./nano": {
      "default": "./dist/nano-extractor.js",
      "types": "./dist/nano-extractor.d.ts"
    }
  },
  "peerDependencies": {
    "llama.rn": ">=0.8.0",
    "react-native-fs": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "llama.rn": {
      "optional": true
    },
    "react-native-fs": {
      "optional": true
    }
  },
  "bin": {
    "llmizeoff": "dist/cli.js",
    "offl-llama": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "download": "node dist/cli.js download",
    "dev": "ts-node src/server.ts"
  },
  "keywords": [
    "llmizeoff",
    "llmize",
    "offllama",
    "llama",
    "llm",
    "self-hosted",
    "cpanel",
    "shared-hosting",
    "inference",
    "openai-compatible",
    "react-native",
    "android",
    "browser",
    "edge",
    "offline-ai",
    "vps",
    "privacy"
  ],
  "author": "Zulqurnain Haider",
  "license": "MIT",
  "dependencies": {
    "node-llama-cpp": "^3.0.0",
    "express": "^4.18.2",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zulqurnain/llmizeoff.git"
  }
}
