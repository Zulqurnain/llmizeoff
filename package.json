{
  "name": "offllama",
  "version": "0.2.0",
  "description": "offLLama — Run llama.cpp inference on any Node.js host (cPanel, shared hosting). Universal HTTP client for browser, React Native, Kotlin/JS. No VPS or GPU required.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/client.js",
      "react-native": "./dist/client.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "default": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "default": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "bin": {
    "offl-llama": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "download": "node dist/cli.js download",
    "dev": "ts-node src/server.ts"
  },
  "keywords": [
    "offllama", "llama", "llm", "cpanel", "shared-hosting", "inference",
    "openai-compatible", "react-native", "browser", "edge", "offline-ai"
  ],
  "author": "Zulqurnain Haider",
  "license": "MIT",
  "dependencies": {
    "node-llama-cpp": "^3.0.0",
    "express": "^4.18.2",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zulqurnain/offllama.git"
  }
}
