{
  "name": "offllama",
  "version": "0.1.0",
  "description": "offLLama — Run llama.cpp inference on any Node.js host (cPanel, shared hosting). No VPS or GPU required. OpenAI-compatible API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "offl-llama": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/server.js",
    "download": "node dist/cli.js download",
    "dev": "ts-node src/server.ts"
  },
  "keywords": ["offllama", "llama", "llm", "cpanel", "shared-hosting", "inference", "openai-compatible"],
  "author": "Zulqurnain Haider",
  "license": "MIT",
  "dependencies": {
    "node-llama-cpp": "^3.0.0",
    "express": "^4.18.2",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zulqurnain/offllama.git"
  }
}
